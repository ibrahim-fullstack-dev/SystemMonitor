<Window x:Class="UI.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UI.Desktop"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
        <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0"  Background="#252538">
            <TextBlock Text="IBRAHIM" Foreground="#7C4DFF" FontSize="24" FontWeight="Bold" Margin="30,40,0,10"/>
            <TextBlock Text="MONITOR" Foreground="White" FontSize="18" FontWeight="Light" Margin="30,0,0,50"/>

            <Button Content="CPU"  Background="#35354A" Foreground="#A0A0B0" BorderThickness="0" Height="45" Margin="10,5" Cursor="Hand"/>
            <Button Content="RAM" Background="Transparent" Foreground="#A0A0B0" BorderThickness="0" Height="45" Margin="10,5" Cursor="Hand"/>
            <Button Content="Storage" Background="Transparent" Foreground="#A0A0B0" BorderThickness="0" Height="45" Margin="10,5" Cursor="Hand"/>
            <Button Content="Exit"  VerticalAlignment="Bottom" Background="#FF4B4B" Foreground="White" Height="45" Margin="10,5" Cursor="Hand" />
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="30">
            <TextBlock Text="Storage Overview" Foreground="White" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,30"/>

            <ItemsControl x:Name="DrivesContainer">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#2B2B3F" CornerRadius="15" Padding="20" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Ellipse Width="50" Height="50" Fill="#7C4DFF" Grid.Column="0"/>

                                <StackPanel Grid.Column="1" Margin="20,0,0,0">
                                    <Grid>
                                        <TextBlock Text="{Binding DriveName}" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding UsagePercent, StringFormat={}{0}%}" Foreground="#A0A0B0" HorizontalAlignment="Right"/>
                                    </Grid>

                                    <ProgressBar Value="{Binding UsagePercent}" Height="10" Margin="0,10,0,10" Background="#3D3D5C" Foreground="#7C4DFF" BorderThickness="0"/>

                                    <TextBlock Text="{Binding SpaceInfo}" Foreground="#A0A0B0" FontSize="12"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
        <!--</Border>-->
</Window>
