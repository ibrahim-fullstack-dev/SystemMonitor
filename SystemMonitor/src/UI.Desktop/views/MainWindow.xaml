<Window x:Class="UI.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UI.Desktop"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:vms="clr-namespace:UI.Desktop.Global"
        xmlns:controls="clr-namespace:UI.Desktop.Views.Controls"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vms:clsMainViewModel, IsDesignTimeCreatable=True}"
        Title="System Monitor" Height="450" Width="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Background="#1E1E1E">
            <TextBlock Text="Ibrahim Monitor" Foreground="White" Margin="0,0,0,20" FontWeight="Bold"/>
            <Button Content="CPU Dashboard" Command="{Binding ShowCpuCommand}" Margin="0,5"/>
            <Button Content="RAM Details" Command="{Binding ShowRamCommand}" Margin="0,5"/>
        </StackPanel>

        <ScrollViewer Grid.Column="1" Background="#121212">
            <StackPanel Margin="10">
                <controls:ctrlMonitorChart DataContext="{Binding CPUVM}" Height="250" Margin="0,0,0,15"/>
                <controls:ctrlMonitorChart DataContext="{Binding RAMVM}" Height="250" Margin="0,0,0,15"/>
                <controls:ctrlMonitorChart DataContext="{Binding StorageVM}" Height="250"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>