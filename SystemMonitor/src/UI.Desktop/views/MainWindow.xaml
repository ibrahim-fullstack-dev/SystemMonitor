<Window x:Class="UI.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UI.Desktop"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:vms="clr-namespace:UI.Desktop.Global"
        xmlns:controls="clr-namespace:UI.Desktop.Views.Controls"
        mc:Ignorable="d"
        Title="System Monitor" Height="450" Width="800">

    <Grid Background="#121212">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="0,20,20,0">
            <StackPanel Margin="20">
                <TextBlock Text="IBRAHIM MONITOR" 
                       Foreground="#00FF7F" 
                       FontSize="18" 
                       FontWeight="ExtraBold" 
                       Margin="0,0,0,40"
                       HorizontalAlignment="Center"/>

                <Button Content="CPU Dashboard" 
                    Command="{Binding ShowCpuCommand}" 
                    Style="{DynamicResource SideButton}"/>

                <Button Content="RAM Details" 
                    Command="{Binding ShowRamCommand}" 
                    Style="{DynamicResource SideButton}"
                    Margin="0,10"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30">
                <TextBlock Text="System Performance" 
                       Foreground="White" 
                       FontSize="22" 
                       FontWeight="SemiBold" 
                       Margin="0,0,0,20"/>

                <Border Background="#1E1E1E" 
                    CornerRadius="15" 
                    Padding="15" 
                    BorderBrush="#333333" 
                    BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="CPU Utilization" Foreground="#AAAAAA" Margin="0,0,0,10"/>
                        <controls:ctrlMonitorChart DataContext="{Binding CPUVM}" Height="300" Width="Auto"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>