<UserControl
    x:Class="UI.Desktop.Views.Controls.ctrlMonitorChart"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:vms="clr-namespace:UI.Desktop.ViewModels;assembly=UI.Desktop">

    <Grid Margin="20">
        <lvc:CartesianChart Series="{Binding Series}" YAxes="{Binding YAxes}" XAxes="{Binding XAxes}" Background="#1E1E1E">
        </lvc:CartesianChart>
    </Grid>

</UserControl>
